# Supabase — облачное сохранение проектов (необязательно).
# Без этих переменных проекты сохраняются в localStorage браузера.
# Возьми значения в Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

